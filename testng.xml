<?xml version="1.0" encoding="UTF-8"?>
<!--
    TestNG Suite File
    Purpose: Runs the same tests across Chrome, Firefox, and Edge in parallel.
    Why this way: `parallel="methods"` runs @Test methods in parallel; `thread-count`
    controls the maximum number of concurrent test threads.
-->
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="HybridQAFramework Cross Browser Suite" parallel="methods" thread-count="3">

    <test name="ChromeTests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.hybrid.tests.LoginTest"/>
            <class name="com.hybrid.tests.HomeTest"/>
        </classes>
    </test>

    <test name="FirefoxTests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.hybrid.tests.LoginTest"/>
            <class name="com.hybrid.tests.HomeTest"/>
        </classes>
    </test>

    <test name="EdgeTests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.hybrid.tests.LoginTest"/>
            <class name="com.hybrid.tests.HomeTest"/>
        </classes>
    </test>

</suite>
