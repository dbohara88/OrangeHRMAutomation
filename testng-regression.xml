<?xml version="1.0" encoding="UTF-8"?>
<!--
    Regression Suite
    Purpose: Dedicated suite file for running regression-focused coverage when the team
    does not want the full cross-browser matrix.
-->
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="HybridQAFramework Regression Suite" parallel="methods" thread-count="2">

    <test name="Regression-Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.hybrid.tests.LoginTest"/>
            <class name="com.hybrid.tests.HomeTest"/>
        </classes>
    </test>

</suite>
